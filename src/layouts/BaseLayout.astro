---
import { business } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/og-default.jpg',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const fullTitle = title === 'Home'
  ? `${business.name} | ${business.tagline} | North Myrtle Beach, SC`
  : `${title} | ${business.name} | North Myrtle Beach, SC`;

/* JSON-LD: LocalBusiness structured data — critical for local SEO */
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'BeautySalon',
  name: business.name,
  description: business.description,
  url: 'https://yourfreshface.com',
  telephone: business.phone,
  address: {
    '@type': 'PostalAddress',
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.state,
    postalCode: business.address.zip,
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: business.coordinates.lat,
    longitude: business.coordinates.lng,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '09:00',
      closes: '17:00',
    },
  ],
  priceRange: '$$',
  image: 'https://yourfreshface.com/og-default.jpg',
  hasMap: 'https://www.google.com/maps/search/?api=1&query=Fresh+Face+Studio+North+Myrtle+Beach+SC',
  areaServed: ['North Myrtle Beach', 'Myrtle Beach', 'Little River', 'Conway', 'Surfside Beach', 'Garden City', "Murrell's Inlet", 'Pawleys Island'],
  paymentAccepted: 'Cash, Credit Card',
  currenciesAccepted: 'USD',
  sameAs: [
    business.social.instagram,
    business.social.facebook,
  ].filter(Boolean),
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary Meta -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={business.name} />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Geo Meta — helps local search -->
  <meta name="geo.region" content="US-SC" />
  <meta name="geo.placename" content="North Myrtle Beach" />
  <meta name="geo.position" content={`${business.coordinates.lat};${business.coordinates.lng}`} />
  <meta name="ICBM" content={`${business.coordinates.lat}, ${business.coordinates.lng}`} />

  <!-- Theme & manifest -->
  <meta name="theme-color" content="#2D2926" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="sitemap" href="/sitemap.xml" />

  <!-- Favicon — TODO: Replace with actual brand favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Nunito+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <slot name="head" />
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to content</a>

  <slot name="header" />

  <main id="main-content" aria-label="Main content">
    <slot />
  </main>

  <slot name="footer" />
</body>
</html>
