---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { business } from '../data/site';
---

<BaseLayout
  title="About"
  description="Fresh Face Studio is a boutique esthetician studio inside a renovated 1950s beach bungalow in North Myrtle Beach, SC. Meet Maria and learn why personal skincare matters."
>
  <Header slot="header" currentPath="/about" />

  <!-- FULL-BLEED HERO -->
  <section class="page-hero-img" aria-label="About Fresh Face Studio">
    <img
      src="/images/maria-studio.jpg"
      alt="Maria in the Fresh Face Studio treatment room"
      class="page-hero-img__bg"
      loading="eager"
    />
    <div class="page-hero-img__content">
      <p class="about-eyebrow">Meet Your Esthetician</p>
      <h1>About Fresh Face Studio</h1>
      <p>It's not just skincare. It's soul care.</p>
    </div>
  </section>

  <!-- SPLIT: Soul Care story -->
  <section class="split-section" aria-labelledby="soul-care-heading">
    <div class="split-section__img">
      <img
        src="/images/maria-headshot.jpg"
        alt="Maria, licensed esthetician and owner of Fresh Face Studio"
        loading="lazy"
      />
    </div>
    <div class="split-section__body split-section__body--padded">
      <p class="about-eyebrow">The Philosophy</p>
      <h2 id="soul-care-heading">It's Not Just Skincare.<br />It's Soul Care.</h2>
      <p class="text-secondary" style="margin-top:var(--space-lg);">
        Fresh Face Studio started because Maria believed skincare should feel like visiting
        a friend — not checking into a medical office. So she found a 1950s beach bungalow,
        filled it with natural light and good energy, and built the kind of studio she'd
        want to visit herself.
      </p>
      <p class="text-secondary">
        When you come to Fresh Face, you're not a number on a schedule. You're a person
        with a face that has a story. Maria takes the time to listen — to what your skin
        is telling her, and to what you're telling her over conversation. Turns out,
        both matter.
      </p>
      <p class="text-secondary">
        The treatments are professional-grade. The products are top-tier. But what keeps
        people coming back? It's the feeling. That "I just left the best friend I didn't
        know I had" feeling. That's the Fresh Face difference.
      </p>
      <a href="/book" class="btn btn--primary btn--gg" style="margin-top:var(--space-xl); align-self:flex-start;">
        Book Your First Visit
      </a>
    </div>
  </section>

  <!-- SPLIT: The Bungalow (reversed) -->
  <section class="split-section" style="background:var(--bg-secondary);" aria-labelledby="bungalow-about-heading">
    <div class="split-section__body split-section__body--padded split-section__body--reversed">
      <p class="about-eyebrow">The Space</p>
      <h2 id="bungalow-about-heading">The Bungalow</h2>
      <p class="text-secondary" style="margin-top:var(--space-lg);">
        Clients call it "the happy place." It's a renovated 1950s beach house with all the charm
        you'd expect — plus professional-grade skincare equipment you wouldn't. Natural light,
        warm vibes, and the kind of quiet that makes you forget you have a phone.
      </p>
      <p class="text-secondary">
        There's no front desk. No waiting room full of strangers. When you're here, the whole
        place is yours.
      </p>
      <a href="/book" class="btn btn--sage" style="margin-top:var(--space-xl); align-self:flex-start;">
        Come See It
      </a>
    </div>
    <div class="split-section__img">
      <img
        src="/images/treatment-room.jpg"
        alt="Treatment room inside the Fresh Face Studio beach bungalow"
        loading="lazy"
      />
    </div>
  </section>

  <!-- STUDIO GALLERY -->
  <section class="section" aria-labelledby="gallery-heading">
    <div class="container">
      <div class="section-header">
        <p class="about-eyebrow">Inside the Studio</p>
        <h2 id="gallery-heading">A Space Made for You</h2>
      </div>
      <div class="studio-gallery">
        <div class="gallery-item gallery-item--wide">
          <img
            src="/images/studio-shelves.jpg"
            alt="Skincare product shelves at Fresh Face Studio"
            loading="lazy"
          />
        </div>
        <div class="gallery-item">
          <img
            src="/images/treatment-room.jpg"
            alt="Treatment room interior at Fresh Face Studio"
            loading="lazy"
          />
        </div>
        <div class="gallery-item">
          <img
            src="/images/studio-vanity.jpg"
            alt="Studio vanity area at Fresh Face Studio"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- INFO GRID -->
  <section class="section section--alt" aria-labelledby="info-heading">
    <div class="container container--narrow">
      <h2 id="info-heading" style="text-align:center; margin-bottom:var(--space-2xl);">Plan Your Visit</h2>
      <div class="info-grid">
        <div class="info-block">
          <h3>Location</h3>
          <p>
            {business.address.street}<br />
            {business.address.city}, {business.address.state} {business.address.zip}
          </p>
        </div>
        <div class="info-block">
          <h3>Hours</h3>
          <p>Monday – Saturday: 9 AM – 5 PM<br />Sunday: Closed</p>
        </div>
        <div class="info-block">
          <h3>Contact</h3>
          <p>
            <a href={`tel:${business.phone.replace(/[^0-9]/g, '')}`} class="info-phone">{business.phone}</a>
          </p>
        </div>
        <div class="info-block">
          <h3>Cancellation Policy</h3>
          <p>
            30% cancellation fee for no-shows or cancellations within 24 hours of your appointment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- BOOKING CTA -->
  <section class="about-cta" aria-labelledby="about-cta-heading">
    <div class="about-cta__overlay"></div>
    <div class="container about-cta__content">
      <h2 id="about-cta-heading">Come See What Everyone's Talking About</h2>
      <p>Book your first visit to the bungalow.</p>
      <a href="/book" class="btn btn--primary btn--gg btn--lg">Book Your Appointment</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .about-eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }

  /* SPLIT SECTIONS */
  .split-section {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .split-section { grid-template-columns: 1fr 1fr; }
  }

  .split-section__img {
    position: relative;
    min-height: 480px;
    background: var(--color-charcoal);
    overflow: hidden;
  }
  .split-section__img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .split-section__body--padded {
    padding: var(--space-5xl) var(--space-3xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (max-width: 767px) {
    .split-section__body--padded { padding: var(--space-2xl) var(--space-lg); }
  }
  .split-section__body--padded h2 {
    margin-top: var(--space-sm);
    margin-bottom: 0;
  }
  .split-section__body--padded p {
    margin-top: var(--space-md);
  }

  /* Reversed on desktop */
  @media (min-width: 768px) {
    .split-section__body--reversed {
      order: -1;
    }
  }

  /* GALLERY */
  .studio-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-md);
  }
  @media (max-width: 640px) {
    .studio-gallery { grid-template-columns: 1fr; }
    .gallery-item--wide { grid-column: 1; }
  }
  @media (min-width: 641px) {
    .gallery-item--wide {
      grid-column: 1;
      grid-row: 1 / 3;
    }
  }
  .gallery-item {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    background: var(--bg-secondary);
    aspect-ratio: 4/3;
  }
  .gallery-item--wide {
    aspect-ratio: unset;
    min-height: 300px;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--border-radius-lg);
    display: block;
    transition: transform 0.5s ease;
  }
  .gallery-item:hover img {
    transform: scale(1.04);
  }

  /* INFO GRID */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }
  @media (max-width: 600px) {
    .info-grid { grid-template-columns: 1fr; }
  }
  .info-block h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }
  .info-block p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.8;
  }
  .info-phone {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary) !important;
  }
  .info-phone:hover {
    color: var(--accent) !important;
  }

  /* BOOKING CTA */
  .about-cta {
    position: relative;
    background: var(--color-sage);
    padding: var(--space-5xl) 0;
    overflow: hidden;
  }
  .about-cta__overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(90,107,79,0.6) 0%, transparent 70%);
  }
  .about-cta__content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .about-cta__content h2 {
    color: white;
    margin-bottom: var(--space-md);
  }
  .about-cta__content p {
    color: rgba(255,255,255,0.82);
    margin-bottom: var(--space-xl);
    font-size: var(--text-lg);
  }
</style>
