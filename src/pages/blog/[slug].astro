---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { business } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: post.data.author || business.name,
  },
  publisher: {
    '@type': 'Organization',
    name: business.name,
    url: 'https://freshfacestudio.com',
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <Header slot="header" currentPath="/blog" />

  <article class="blog-post">
    <div class="container container--narrow">
      <a href="/blog" class="back-link">&larr; Back to Skin School</a>

      <header class="blog-post__header">
        <h1>{post.data.title}</h1>
        <div class="blog-post__meta">
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
          {post.data.author && (
            <span class="blog-post__author">by {post.data.author}</span>
          )}
        </div>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="blog-post__tags">
            {post.data.tags.map(tag => (
              <span class="tag-pill">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="prose">
        <Content />
      </div>

      <div class="blog-cta">
        <h3>Ready to take care of your skin?</h3>
        <p>
          Book a treatment at Fresh Face Studio and get personalized care
          from a licensed esthetician in North Myrtle Beach.
        </p>
        <a href="/book" class="btn btn--primary">Book an Appointment</a>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .blog-post {
    padding: var(--space-2xl) 0 var(--space-4xl);
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    margin-bottom: var(--space-xl);
    transition: color var(--transition-fast);
  }
  .back-link:hover {
    color: var(--accent);
  }

  .blog-post__header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
  }
  .blog-post__header h1 {
    margin-bottom: var(--space-md);
  }

  .blog-post__meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  .blog-post__author::before {
    content: '';
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .tag-pill {
    display: inline-block;
    padding: 0.25em 0.75em;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-accent);
    background: var(--bg-accent);
    border-radius: 999px;
    letter-spacing: 0.02em;
  }

  /* ===== Prose: Markdown content typography ===== */
  .prose {
    line-height: 1.8;
    font-size: var(--text-lg);
  }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    color: var(--text-primary);
  }
  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
  }

  .prose :global(p) {
    margin-bottom: var(--space-md);
    color: var(--text-secondary);
  }

  .prose :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) {
    color: var(--accent-hover);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-xl);
    color: var(--text-secondary);
  }
  .prose :global(li) {
    margin-bottom: var(--space-xs);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-lg);
    margin: var(--space-xl) 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-xl) 0;
    font-size: var(--text-sm);
  }
  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--border);
    text-align: left;
  }
  .prose :global(th) {
    background: var(--bg-secondary);
    font-weight: 600;
    color: var(--text-primary);
  }
  .prose :global(td) {
    color: var(--text-secondary);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--space-2xl) 0;
  }

  .prose :global(img) {
    border-radius: var(--border-radius);
    margin: var(--space-xl) 0;
  }

  /* ===== Booking CTA ===== */
  .blog-cta {
    margin-top: var(--space-3xl);
    padding: var(--space-2xl);
    background: var(--bg-secondary);
    border-radius: var(--border-radius-lg);
    text-align: center;
  }
  .blog-cta h3 {
    margin-bottom: var(--space-sm);
  }
  .blog-cta p {
    color: var(--text-secondary);
    max-width: 460px;
    margin: 0 auto var(--space-lg);
  }
</style>
