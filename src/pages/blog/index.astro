---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<BaseLayout
  title="Skin School — Skincare Tips & Education"
  description="Expert skincare tips, treatment guides, and coastal skin advice from a licensed esthetician in North Myrtle Beach, SC. Learn how to take care of your skin between appointments."
>
  <Header slot="header" currentPath="/blog" />

  <!-- HERO -->
  <section class="page-hero-img" aria-label="Skin School blog">
    <img
      src="/images/eye-treatment.jpg"
      alt="Eye area skincare treatment at Fresh Face Studio"
      class="page-hero-img__bg"
      loading="eager"
    />
    <div class="page-hero-img__content">
      <p class="blog-eyebrow">Education &amp; Expertise</p>
      <h1>Skin School</h1>
      <p>
        Honest skincare education from a licensed esthetician. No sponsored content.
        No affiliate tricks. Just what actually works for your skin.
      </p>
    </div>
  </section>

  <!-- POSTS -->
  <section class="section">
    <div class="container container--narrow">
      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map(post => {
            const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            return (
              <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="blog-card">
                <div class="blog-card__body">
                  <time class="blog-card__date" datetime={post.data.pubDate.toISOString()}>
                    {formattedDate}
                  </time>
                  <h2 class="blog-card__title">{post.data.title}</h2>
                  <p class="blog-card__desc">{post.data.description}</p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="blog-card__tags">
                      {post.data.tags.map(tag => (
                        <span class="tag-pill">{tag}</span>
                      ))}
                    </div>
                  )}
                  <span class="blog-card__link">Read article &rarr;</span>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="blog-empty">
          <h2>Coming Soon</h2>
          <p>
            We're building out our skincare education library. In the meantime,
            follow us on social media for tips and updates, or book a consultation
            to get personalized advice in person.
          </p>
          <p class="blog-empty__note">
            <strong>Content planned:</strong> Coastal skin survival tips, chemical peel vs. microneedling guide,
            skincare ingredient breakdowns, seasonal routine adjustments for beach living,
            and myth-busting the most common skincare advice.
          </p>
          <a href="/book" class="btn btn--primary" style="margin-top:var(--space-xl);">Book a Consultation</a>
        </div>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .blog-eyebrow {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-terracotta);
    margin-bottom: var(--space-sm);
  }

  .blog-grid {
    display: grid;
    gap: var(--space-xl);
  }

  .blog-card {
    display: block;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .blog-card:hover {
    box-shadow: 0 4px 24px rgba(44, 40, 37, 0.08);
    border-color: var(--accent);
  }

  .blog-card__body {
    padding: var(--space-xl);
  }

  .blog-card__date {
    display: block;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }

  .blog-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .blog-card__desc {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .tag-pill {
    display: inline-block;
    padding: 0.25em 0.75em;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-accent);
    background: var(--bg-accent);
    border-radius: 999px;
    letter-spacing: 0.02em;
  }

  .blog-card__link {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.02em;
  }
  .blog-card:hover .blog-card__link {
    color: var(--accent-hover);
  }

  .blog-empty {
    text-align: center;
    padding: var(--space-3xl) 0;
  }
  .blog-empty h2 {
    margin-bottom: var(--space-md);
  }
  .blog-empty p {
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }
  .blog-empty__note {
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    background: var(--bg-secondary);
    border-radius: var(--border-radius);
    font-size: var(--text-sm);
    text-align: left;
  }
</style>
