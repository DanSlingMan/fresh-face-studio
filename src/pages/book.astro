---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { business, services } from '../data/site';

const calendlyUrl = 'https://calendly.com/freshface-sc';
const isCalendlyLive = true;
---

<BaseLayout
  title="Book an Appointment"
  description="Book a facial, chemical peel, microneedling, or any skincare treatment at Fresh Face Studio in North Myrtle Beach, SC. Online scheduling available."
>
  <Header slot="header" currentPath="/book" />

  <!-- HERO -->
  <section class="page-hero-img" aria-label="Book an appointment">
    <img
      src="/images/facial-relaxed.jpg"
      alt="Client relaxing during a facial treatment at Fresh Face Studio"
      class="page-hero-img__bg"
      loading="eager"
    />
    <div class="page-hero-img__content">
      <p class="book-eyebrow">Schedule Your Visit</p>
      <h1>Book an Appointment</h1>
      <p>
        Pick a service, pick a time, and leave the rest to Maria. Every treatment is
        customized the moment she sees your skin.
      </p>
    </div>
  </section>

  <!-- BOOKING SECTION -->
  <section class="section">
    <div class="container">
      {isCalendlyLive ? (
        <Fragment>
          <div
            class="calendly-inline-widget"
            data-url={`${calendlyUrl}?hide_gdpr_banner=1&primary_color=c17b5a`}
            style="min-width:320px;height:700px;"
          ></div>
          <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
          <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>
        </Fragment>
      ) : (
        <div class="booking-fallback">
          <div class="booking-card">
            <h2>Online Booking Coming Soon</h2>
            <p>
              We're setting up online scheduling. In the meantime, give us a call.
            </p>
            <div class="booking-card__actions">
              <a href={`tel:${business.phone.replace(/[^0-9]/g, '')}`} class="btn btn--primary btn--lg">
                Call {business.phone}
              </a>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- SERVICES PRICING LIST -->
  <section class="section section--alt">
    <div class="container container--narrow">
      <h2 style="text-align:center; margin-bottom:var(--space-xl);">Services &amp; Pricing</h2>
      <div class="services-menu">
        {services.map(service => (
          <div class="services-menu__item">
            <div class="services-menu__info">
              <span class="services-menu__name">{service.name}</span>
              <span class="services-menu__dots"></span>
              <span class="services-menu__price">
                {'priceNote' in service ? `${(service as any).priceNote} ` : ''}${service.price}
              </span>
            </div>
            <span class="services-menu__duration">{service.duration} min</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INFO CARDS -->
  <section class="section">
    <div class="container">
      <div class="info-grid">
        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">✦</div>
          <h3>Before Your Visit</h3>
          <p>
            Arrive with a clean face if possible. Let us know about any medications,
            allergies, or recent skin treatments. First-time clients should arrive
            5 minutes early.
          </p>
        </div>
        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">✦</div>
          <h3>Cancellation Policy</h3>
          <p>
            We understand plans change. Cancellations within 24 hours of your
            appointment are subject to a 30% service fee. No-shows are charged
            the full service price.
          </p>
        </div>
        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">✦</div>
          <h3>House Calls</h3>
          <p>
            Can't make it to the studio? We offer house calls for select treatments
            within the North Myrtle Beach area. Call us to check availability
            and pricing.
          </p>
        </div>
        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">✦</div>
          <h3>Not Sure What You Need?</h3>
          <p>
            No problem. Book a Classic Facial and we'll assess your skin during
            the treatment. We'll recommend a plan based on what we see — no
            pressure, just honest advice.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .book-eyebrow {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-terracotta);
    margin-bottom: var(--space-sm);
  }

  .booking-fallback {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }
  .booking-card {
    text-align: center;
    padding: var(--space-3xl);
    background: var(--bg-secondary);
    border-radius: var(--border-radius-lg);
  }
  .booking-card h2 {
    margin-bottom: var(--space-md);
  }
  .booking-card p {
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto var(--space-xl);
  }
  .booking-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
  }

  .services-menu {
    display: grid;
    gap: 0;
  }
  .services-menu__item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border);
  }
  .services-menu__item:last-child {
    border-bottom: none;
  }
  .services-menu__info {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex: 1;
    min-width: 0;
  }
  .services-menu__name {
    font-weight: 600;
    white-space: nowrap;
    font-size: var(--text-sm);
  }
  .services-menu__dots {
    flex: 1;
    border-bottom: 2px dotted var(--border);
    min-width: 20px;
    align-self: center;
    margin-bottom: 4px;
  }
  .services-menu__price {
    font-weight: 700;
    color: var(--accent);
    white-space: nowrap;
    font-size: var(--text-sm);
  }
  .services-menu__duration {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }
  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
  }
  .info-card {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-xl);
  }
  .info-card__icon {
    font-size: var(--text-lg);
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }
  .info-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }
  .info-card p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.7;
  }
</style>
