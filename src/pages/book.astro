---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { business, services, serviceCategories, GLOSSGENIUS_URLS } from '../data/site';

function truncate(text: string, max: number): string {
  return text.length <= max ? text : text.slice(0, max).trimEnd() + '…';
}
---

<BaseLayout
  title="Book an Appointment"
  description="Book a facial, chemical peel, microneedling, or any skincare treatment at Fresh Face Studio in North Myrtle Beach, SC. Online scheduling available."
>
  <Header slot="header" currentPath="/book" />

  <!-- 1. HERO -->
  <section class="page-hero-img" aria-label="Book an appointment">
    <img
      src="/images/facial-treatment.jpg"
      alt="Client receiving a personalized facial treatment at Fresh Face Studio"
      class="page-hero-img__bg"
      loading="eager"
    />
    <div class="page-hero-img__content">
      <p class="book-eyebrow">Schedule Your Visit</p>
      <h1>Book Your Visit</h1>
      <p>Pick a service, pick a time, and leave the rest to Maria.</p>
    </div>
  </section>

  <!-- 2. SERVICE BOOKING GRID -->
  {serviceCategories.map((category, i) => {
    const categoryServices = services.filter(s => s.category === category.slug);
    if (categoryServices.length === 0) return null;
    const isAlt = i % 2 !== 0;
    return (
      <section
        class={`section booking-category${isAlt ? ' section--alt' : ''}`}
        id={`book-${category.slug}`}
      >
        <div class="container">
          <div class="booking-category__header">
            <h2>{category.name}</h2>
            <p class="text-secondary">{category.description}</p>
          </div>
          <div class="booking-grid">
            {categoryServices.map(service => (
              <div class="booking-card">
                <div class="booking-card__body">
                  <div class="booking-card__meta">
                    <span class="booking-card__duration">{service.duration} min</span>
                    <span class="booking-card__price">
                      {'priceNote' in service
                        ? `From $${service.price}`
                        : `$${service.price}`}
                    </span>
                  </div>
                  <h3 class="booking-card__name">{service.name}</h3>
                  <p class="booking-card__desc">
                    {truncate(service.shortDescription, 80)}
                  </p>
                </div>
                <div class="booking-card__footer">
                  <a
                    href={GLOSSGENIUS_URLS.booking}
                    class="btn btn--primary booking-card__btn"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Book ${service.name} on GlossGenius`}
                  >
                    Book Now
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <!-- 3. PHONE CTA -->
  <section class="phone-cta">
    <div class="container">
      <p>
        Prefer to book by phone?&nbsp;
        <a href={`tel:${business.phone.replace(/[^0-9]/g, '')}`} class="phone-cta__link">
          Call {business.phone}
        </a>
      </p>
    </div>
  </section>

  <!-- 4. INFO CARDS -->
  <section class="section section--alt" aria-labelledby="info-heading">
    <div class="container">
      <h2 id="info-heading" class="info-section__heading">Good to Know</h2>
      <div class="info-grid">
        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">✦</div>
          <h3>Before Your Visit</h3>
          <p>
            Arrive with a clean face if possible. Let us know about any medications,
            allergies, or recent skin treatments. First-time clients should arrive
            5 minutes early.
          </p>
        </div>
        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">✦</div>
          <h3>Cancellation Policy</h3>
          <p>
            We understand plans change. Cancellations within 24 hours of your
            appointment are subject to a 30% service fee. No-shows are charged
            the full service price.
          </p>
        </div>
        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">✦</div>
          <h3>House Calls</h3>
          <p>
            Can't make it to the studio? We offer house calls for select treatments
            within the North Myrtle Beach area. Call us to check availability
            and pricing.
          </p>
        </div>
        <div class="info-card">
          <div class="info-card__icon" aria-hidden="true">✦</div>
          <h3>Not Sure What You Need?</h3>
          <p>
            No problem. Book a Classic Facial and we'll assess your skin during
            the treatment. We'll recommend a plan based on what we see — no
            pressure, just honest advice.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* HERO EYEBROW */
  .book-eyebrow {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-terracotta);
    margin-bottom: var(--space-sm);
  }

  /* CATEGORY HEADER */
  .booking-category__header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }
  .booking-category__header h2 {
    margin-bottom: var(--space-xs);
  }

  /* BOOKING GRID */
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 600px) {
    .booking-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .booking-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* BOOKING CARD */
  .booking-card {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--border-radius-lg);
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--transition-base), transform var(--transition-base), border-color var(--transition-base);
  }
  .booking-card:hover {
    box-shadow: 0 8px 32px rgba(44, 40, 37, 0.1);
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .booking-card__body {
    padding: var(--space-xl) var(--space-xl) var(--space-md);
    flex: 1;
  }

  .booking-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }
  .booking-card__duration {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }
  .booking-card__price {
    font-size: var(--text-lg);
    font-weight: 700;
    font-family: var(--font-serif);
    color: var(--accent);
  }

  .booking-card__name {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }

  .booking-card__desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .booking-card__footer {
    padding: var(--space-md) var(--space-xl) var(--space-xl);
  }
  .booking-card__btn {
    width: 100%;
    justify-content: center;
  }

  /* PHONE CTA */
  .phone-cta {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: var(--space-xl) 0;
    text-align: center;
  }
  .phone-cta p {
    font-size: var(--text-lg);
    color: var(--text-secondary);
  }
  .phone-cta__link {
    font-weight: 700;
    font-family: var(--font-serif);
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }
  .phone-cta__link:hover {
    color: var(--accent);
  }

  /* INFO SECTION */
  .info-section__heading {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }
  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
  }

  .info-card {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-xl);
  }
  .info-card__icon {
    font-size: var(--text-lg);
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }
  .info-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }
  .info-card p {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.7;
  }
</style>
