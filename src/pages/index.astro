---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { business, services, GLOSSGENIUS_URLS } from '../data/site';
---

<BaseLayout
  title="Home"
  description="Fresh Face Studio is a boutique skincare studio in North Myrtle Beach, SC. Personalized facials, chemical peels, microneedling & more in a renovated 1950s beach bungalow. Book your appointment today."
>
  <Header slot="header" currentPath="/" />

  <!-- 1. FULL-BLEED HERO -->
  <section class="hero-fullbleed" aria-label="Welcome to Fresh Face Studio">
    <div class="hero-fullbleed__bg" style="background-image:url('/images/facial-relaxed.jpg')"></div>
    <div class="hero-fullbleed__overlay"></div>
    <div class="hero-fullbleed__content container">
      <p class="hero-eyebrow">North Myrtle Beach, SC</p>
      <h1 class="hero-title">
        You Came for a Facial.<br />
        <em>You'll Leave with a Friend.</em>
      </h1>
      <p class="hero-subtitle">
        Fresh Face Studio is where real skincare meets real connection. Custom facials
        and advanced treatments in a cozy 1950s beach bungalow — no rushing, no upselling,
        just Maria, your skin, and a whole lot of good conversation.
      </p>
      <div class="hero-actions">
        <a href="/book" class="btn btn--primary btn--lg">Book Your Visit</a>
        <a href="/services" class="btn btn--outline-white btn--lg">Explore Services</a>
      </div>
    </div>
  </section>

  <!-- 2. TRUST BAR -->
  <section class="trust-bar" aria-label="Why Fresh Face">
    <div class="container">
      <div class="trust-bar__items">
        <div class="trust-item">
          <strong>One-on-One Care</strong>
          <span>It's just you and Maria</span>
        </div>
        <div class="trust-item">
          <strong>House Calls Available</strong>
          <span>We'll come to you</span>
        </div>
        <div class="trust-item">
          <strong>The Bungalow Experience</strong>
          <span>A 1950s beach house, not a strip mall</span>
        </div>
        <div class="trust-item">
          <strong>6 Days a Week</strong>
          <span>Because your skin doesn't take weekends off</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. SERVICE HIGHLIGHTS -->
  <section class="section" aria-labelledby="services-heading">
    <div class="container">
      <div class="section-header fade-in">
        <p class="section-header__eyebrow">What We Do</p>
        <h2 id="services-heading">Treatments Made for You</h2>
        <p class="text-secondary text-lg">
          Every treatment starts with a conversation — not a checklist. Here's what our clients love most.
        </p>
      </div>
      <div class="service-highlights">
        <a href="/services#facials" class="highlight-card fade-in fade-in--delay-1" aria-label="Facials and Skin Care services">
          <div class="highlight-card__img-wrap">
            <img src="/images/facial-treatment.jpg" alt="Client receiving a personalized facial treatment" loading="lazy" />
            <div class="highlight-card__overlay"></div>
          </div>
          <div class="highlight-card__label">
            <h3>Facials &amp; Skin Care</h3>
            <span>Explore &rarr;</span>
          </div>
        </a>
        <a href="/services#advanced" class="highlight-card fade-in fade-in--delay-2" aria-label="Advanced Treatments">
          <div class="highlight-card__img-wrap">
            <img src="/images/microneedling.jpg" alt="Advanced microneedling skin treatment" loading="lazy" />
            <div class="highlight-card__overlay"></div>
          </div>
          <div class="highlight-card__label">
            <h3>Advanced Treatments</h3>
            <span>Explore &rarr;</span>
          </div>
        </a>
        <a href="/services#lash-brow" class="highlight-card fade-in fade-in--delay-3" aria-label="Lash, Brow and Wax services">
          <div class="highlight-card__img-wrap">
            <img src="/images/brow-work.jpg" alt="Brow and lash enhancement treatment" loading="lazy" />
            <div class="highlight-card__overlay"></div>
          </div>
          <div class="highlight-card__label">
            <h3>Lash, Brow &amp; Wax</h3>
            <span>Explore &rarr;</span>
          </div>
        </a>
      </div>
      <div class="section-cta">
        <a href="/services" class="btn btn--secondary">View All {services.length} Services</a>
      </div>
    </div>
  </section>

  <!-- 4. BUNGALOW STORY SPLIT -->
  <section class="split-section split-section--alt" aria-labelledby="bungalow-heading">
    <div class="split-section__img">
      <img src="/images/studio-shelves.jpg" alt="Skincare product shelves and studio interior at Fresh Face" loading="lazy" />
    </div>
    <div class="split-section__body split-section__body--padded">
      <p class="section-header__eyebrow">The Space</p>
      <h2 id="bungalow-heading">
        This Isn't a Spa.<br />
        It's a Beach House with<br />
        Really Good Skincare.
      </h2>
      <p class="text-secondary" style="margin-top:var(--space-lg);">
        Most skincare studios are fluorescent-lit rooms in strip malls or suites in someone
        else's building. Fresh Face Studio is a renovated 1950s beach bungalow — the kind
        of place where you walk in, exhale, and wonder why all appointments can't feel like this.
      </p>
      <p class="text-secondary">
        There's no front desk. No waiting room full of strangers. When you're here, the whole
        place is yours. It's just you, Maria, and whatever your skin needs that day. Plus
        really good conversation — that part's complimentary.
      </p>
      <a href="/about" class="btn btn--sage" style="margin-top:var(--space-xl); align-self:flex-start;">Meet Maria</a>
    </div>
  </section>

  <!-- 5. MEET MARIA SPLIT (reversed) -->
  <section class="split-section split-section--reversed" aria-labelledby="maria-heading">
    <div class="split-section__body split-section__body--padded">
      <p class="section-header__eyebrow">Your Esthetician</p>
      <h2 id="maria-heading">
        It's Not Just Skincare.<br />
        It's Soul Care.
      </h2>
      <p class="text-secondary" style="margin-top:var(--space-lg);">
        Every treatment at Fresh Face starts with a conversation. Maria listens to your skin — and to you. That's the difference between a facial and an experience.
      </p>
      <p class="text-secondary">
        The treatments are professional-grade. The products are top-tier. But what keeps
        people coming back? It's the feeling. That "I just left the best friend I didn't
        know I had" feeling. That's the Fresh Face difference.
      </p>
      <a href="/about" class="btn btn--primary" style="margin-top:var(--space-xl); align-self:flex-start;">Learn More</a>
    </div>
    <div class="split-section__img">
      <img src="/images/maria-headshot.jpg" alt="Maria, licensed esthetician and owner of Fresh Face Studio" loading="lazy" />
    </div>
  </section>

  <!-- 6. TESTIMONIALS -->
  <section class="testimonials section--dark" aria-labelledby="testimonials-heading">
    <div class="container">
      <div class="testimonials__header">
        <p class="section-header__eyebrow" style="color:var(--color-terracotta);">Client Love</p>
        <h2 id="testimonials-heading" style="color:white;">What Our Clients Say</h2>
      </div>
      <div class="testimonial-carousel" id="testimonialCarousel" aria-live="polite">
        <div class="testimonial-slide is-active" role="group" aria-label="Testimonial 1 of 3">
          <svg class="testimonial-quote" viewBox="0 0 40 30" fill="none" aria-hidden="true">
            <path d="M0 30V18C0 12.5 2 8 6 4.5C10 1 15 0 21 0v6C17.5 6 15 7.5 13.5 10.5C12 13.5 12 16.5 12 18h8v12H0ZM22 30V18c0-5.5 2-10 6-13.5C32 1 37 0 43 0v6C39.5 6 37 7.5 35.5 10.5C34 13.5 34 16.5 34 18h8v12H22Z" fill="rgba(193,123,90,0.35)" />
          </svg>
          <blockquote class="testimonial-quote-text">
            <p>"I came in for a facial and left with a friend. Maria makes you feel like the only person in the world."</p>
          </blockquote>
          <cite class="testimonial-cite">— Sarah M.</cite>
        </div>
        <div class="testimonial-slide" role="group" aria-label="Testimonial 2 of 3">
          <svg class="testimonial-quote" viewBox="0 0 40 30" fill="none" aria-hidden="true">
            <path d="M0 30V18C0 12.5 2 8 6 4.5C10 1 15 0 21 0v6C17.5 6 15 7.5 13.5 10.5C12 13.5 12 16.5 12 18h8v12H0ZM22 30V18c0-5.5 2-10 6-13.5C32 1 37 0 43 0v6C39.5 6 37 7.5 35.5 10.5C34 13.5 34 16.5 34 18h8v12H22Z" fill="rgba(193,123,90,0.35)" />
          </svg>
          <blockquote class="testimonial-quote-text">
            <p>"The bungalow is my happy place. There's nothing else like it in Myrtle Beach."</p>
          </blockquote>
          <cite class="testimonial-cite">— Jessica R.</cite>
        </div>
        <div class="testimonial-slide" role="group" aria-label="Testimonial 3 of 3">
          <svg class="testimonial-quote" viewBox="0 0 40 30" fill="none" aria-hidden="true">
            <path d="M0 30V18C0 12.5 2 8 6 4.5C10 1 15 0 21 0v6C17.5 6 15 7.5 13.5 10.5C12 13.5 12 16.5 12 18h8v12H0ZM22 30V18c0-5.5 2-10 6-13.5C32 1 37 0 43 0v6C39.5 6 37 7.5 35.5 10.5C34 13.5 34 16.5 34 18h8v12H22Z" fill="rgba(193,123,90,0.35)" />
          </svg>
          <blockquote class="testimonial-quote-text">
            <p>"My skin has never looked better, and I actually look forward to my appointments. That says everything."</p>
          </blockquote>
          <cite class="testimonial-cite">— Amanda K.</cite>
        </div>
      </div>
      <div class="testimonial-dots" role="tablist" aria-label="Testimonial navigation">
        <button class="testimonial-dot is-active" data-index="0" aria-label="Go to testimonial 1" role="tab" aria-selected="true"></button>
        <button class="testimonial-dot" data-index="1" aria-label="Go to testimonial 2" role="tab" aria-selected="false"></button>
        <button class="testimonial-dot" data-index="2" aria-label="Go to testimonial 3" role="tab" aria-selected="false"></button>
      </div>
    </div>
  </section>

  <!-- 7. GIFT CARDS & MEMBERSHIPS -->
  <section class="section" aria-labelledby="gifts-heading">
    <div class="container">
      <div class="section-header fade-in">
        <p class="section-header__eyebrow">Give & Receive</p>
        <h2 id="gifts-heading">Treat Someone. Treat Yourself.</h2>
      </div>
      <div class="perks-grid">
        <div class="perks-card perks-card--gift fade-in fade-in--delay-1">
          <div class="perks-card__inner">
            <h3>Gift Cards</h3>
            <p>The perfect gift for someone who deserves a little soul care. Available in any amount.</p>
            <a href="/book" class="btn btn--outline-white">Purchase a Gift Card</a>
          </div>
        </div>
        <div class="perks-card perks-card--membership fade-in fade-in--delay-2">
          <div class="perks-card__inner">
            <h3>Memberships</h3>
            <p>Make Fresh Face part of your routine. Monthly membership with exclusive perks and priority booking.</p>
            <a href={GLOSSGENIUS_URLS.memberships} target="_blank" rel="noopener noreferrer" class="btn btn--outline-white">Learn More</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. LOCATION SECTION -->
  <section class="location-section section--alt" aria-labelledby="location-heading">
    <div class="container">
      <div class="location-grid">
        <div class="location-info">
          <p class="section-header__eyebrow">Find Us</p>
          <h2 id="location-heading">Come See the Bungalow</h2>
          <div class="location-details">
            <div class="location-detail">
              <strong>Address</strong>
              <p>
                {business.address.street}<br />
                {business.address.city}, {business.address.state} {business.address.zip}
              </p>
            </div>
            <div class="location-detail">
              <strong>Hours</strong>
              <p>Monday – Saturday: 9 AM – 5 PM<br />Sunday: Closed</p>
            </div>
            <div class="location-detail">
              <strong>Call or Text</strong>
              <p>
                <a href={`tel:${business.phone.replace(/[^0-9]/g, '')}`} class="location-phone">
                  {business.phone}
                </a>
              </p>
            </div>
          </div>
          <a href="/book" class="btn btn--primary" style="margin-top:var(--space-xl);">Book Your Visit</a>
        </div>
        <div class="location-map-wrap">
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(business.address.full)}`}
            target="_blank"
            rel="noopener"
            class="location-map-link"
            aria-label="View Fresh Face Studio on Google Maps"
          >
            <img
              src={`https://maps.googleapis.com/maps/api/staticmap?center=${business.coordinates.lat},${business.coordinates.lng}&zoom=15&size=600x400&maptype=roadmap&markers=color:0xC17B5A%7C${business.coordinates.lat},${business.coordinates.lng}&style=feature:all%7Celement:geometry%7Ccolor:0xf5efe6&key=`}
              alt="Map showing Fresh Face Studio location at 1626 Hwy 17 S, North Myrtle Beach SC"
              loading="lazy"
              onerror="this.parentElement.classList.add('map-fallback')"
            />
            <div class="location-map-overlay">
              <span>View on Google Maps &rarr;</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- LOCAL SEO CONTENT (kept for search visibility) -->
  <section class="section local-seo">
    <div class="container container--narrow">
      <h2>Skincare Services in North Myrtle Beach &amp; the Grand Strand</h2>
      <p class="text-secondary">
        Whether you're a Grand Strand local who's been meaning to find "your person" for skincare,
        or you're visiting the coast and want to treat yourself to something better than a hotel spa —
        you're welcome here. We serve North Myrtle Beach, Myrtle Beach, Little River, Conway,
        Surfside Beach, Garden City, Murrell's Inlet, and Pawleys Island.
      </p>
      <p class="text-secondary">
        Our studio specializes in customized facials, chemical peels, microneedling, dermaplaning,
        nanoneedling, lash lifts, brow lamination, and professional waxing. Every treatment is tailored
        to your individual skin type and concerns — because your skin doesn't look like anyone else's,
        and your treatment shouldn't either.
      </p>
    </div>
  </section>

  <!-- 9. BOOKING CTA (full-bleed image) -->
  <section class="cta-fullbleed" aria-labelledby="cta-heading">
    <div class="cta-fullbleed__bg" style="background-image:url('/images/facial-relaxed.jpg')"></div>
    <div class="cta-fullbleed__overlay"></div>
    <div class="cta-fullbleed__content container">
      <h2 id="cta-heading">Your Skin Has Been Waiting for This</h2>
      <p>Book a visit. We'll figure out what your skin actually needs — together.</p>
      <div class="cta-fullbleed__actions">
        <a href="/book" class="btn btn--primary btn--lg">Book Your Visit</a>
        <a href={`tel:${business.phone.replace(/[^0-9]/g, '')}`} class="cta-phone">
          or call {business.phone}
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero-fullbleed {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-fullbleed__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--color-charcoal);
    z-index: 0;
  }
  .hero-fullbleed__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.42);
    z-index: 1;
  }
  .hero-fullbleed__content {
    position: relative;
    z-index: 2;
    padding: var(--space-5xl) var(--space-lg);
    text-align: center;
  }

  .hero-eyebrow {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-terracotta);
    margin-bottom: var(--space-md);
  }

  .hero-title {
    font-size: var(--text-hero);
    line-height: 1.1;
    color: white;
    margin-bottom: var(--space-lg);
    text-shadow: 0 2px 24px rgba(0,0,0,0.25);
  }
  .hero-title em {
    color: var(--color-terracotta);
    font-style: italic;
  }
  @media (max-width: 768px) {
    .hero-title { font-size: var(--text-4xl); }
  }
  @media (max-width: 480px) {
    .hero-title { font-size: var(--text-3xl); }
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.88);
    max-width: 560px;
    margin: 0 auto var(--space-2xl);
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
  }

  /* ===== TRUST BAR ===== */
  .trust-bar {
    background: var(--bg-secondary);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .trust-bar__items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    text-align: center;
  }
  @media (min-width: 768px) {
    .trust-bar__items {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .trust-item strong {
    display: block;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
    font-family: var(--font-serif);
  }
  .trust-item span {
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  /* ===== SERVICE HIGHLIGHTS ===== */
  .service-highlights {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 600px) {
    .service-highlights { grid-template-columns: repeat(3, 1fr); }
  }

  .highlight-card {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    background: var(--color-charcoal);
  }
  .highlight-card__img-wrap {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
  }
  .highlight-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .highlight-card:hover .highlight-card__img-wrap img {
    transform: scale(1.06);
  }
  .highlight-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,26,26,0.75) 30%, rgba(26,26,26,0.15) 100%);
    transition: background var(--transition-base);
  }
  .highlight-card:hover .highlight-card__overlay {
    background: linear-gradient(to top, rgba(26,26,26,0.85) 40%, rgba(26,26,26,0.25) 100%);
  }
  .highlight-card__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-lg) var(--space-xl);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .highlight-card__label h3 {
    color: white;
    font-size: var(--text-xl);
    line-height: 1.2;
  }
  .highlight-card__label span {
    color: var(--color-terracotta);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    white-space: nowrap;
    transition: transform var(--transition-base);
  }
  .highlight-card:hover .highlight-card__label span {
    transform: translateX(4px);
  }

  .section-cta {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  /* ===== SPLIT SECTIONS ===== */
  .split-section {
    display: grid;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .split-section { grid-template-columns: 1fr 1fr; }
  }
  .split-section--alt {
    background: var(--bg-secondary);
  }
  .split-section--reversed .split-section__img {
    order: 2;
  }
  @media (max-width: 767px) {
    .split-section--reversed .split-section__img { order: 0; }
  }

  .split-section__img {
    position: relative;
    min-height: 420px;
    background: var(--color-charcoal);
    overflow: hidden;
  }
  .split-section__img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .split-section__body--padded {
    padding: var(--space-5xl) var(--space-3xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (max-width: 767px) {
    .split-section__body--padded { padding: var(--space-2xl) var(--space-lg); }
  }
  .split-section__body--padded h2 {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  /* ===== TESTIMONIALS ===== */
  .testimonials {
    padding: var(--space-5xl) 0;
    background: #1e1b18;
    text-align: center;
  }
  .testimonials__header {
    margin-bottom: var(--space-3xl);
  }
  .testimonials__header h2 {
    font-size: var(--text-3xl);
  }

  .testimonial-carousel {
    max-width: 680px;
    margin: 0 auto var(--space-2xl);
    min-height: 200px;
    position: relative;
  }
  .testimonial-slide {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    animation: fadeInUp 0.5s ease;
  }
  .testimonial-slide.is-active {
    display: flex;
  }
  .testimonial-quote {
    width: 48px;
    height: auto;
    margin-bottom: var(--space-sm);
  }
  .testimonial-quote-text p {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-style: italic;
    color: rgba(255,255,255,0.92);
    line-height: 1.6;
  }
  @media (max-width: 768px) {
    .testimonial-quote-text p { font-size: var(--text-xl); }
  }
  .testimonial-cite {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-terracotta);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .testimonial-dots {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
  }
  .testimonial-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    border: none;
    cursor: pointer;
    transition: background var(--transition-base), transform var(--transition-base);
    padding: 0;
  }
  .testimonial-dot.is-active {
    background: var(--color-terracotta);
    transform: scale(1.2);
  }

  /* ===== GIFT CARDS & MEMBERSHIPS ===== */
  .perks-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 640px) {
    .perks-grid { grid-template-columns: 1fr 1fr; }
  }
  .perks-card {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    min-height: 340px;
    display: flex;
