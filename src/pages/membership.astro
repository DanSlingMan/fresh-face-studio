---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const tiers = [
  {
    id: 'member',
    tierKey: 'member',
    name: 'Fresh Face Member',
    price: 89,
    tagline: "The \u201cI'm Serious About My Skin\u201d Tier",
    accent: 'bronze',
    featured: false,
    ribbon: null,
    ctaLabel: 'Join Member Tier',
    perks: [
      { label: '1 Classic Facial per month', note: 'normally $90' },
      { label: '10% off all add-on services' },
      { label: '10% off future product purchases' },
      { label: 'Earn 1 point per $1 spent' },
      { label: 'Free birthday add-on treatment' },
      { label: '48-hour early access to seasonal specials' },
    ],
  },
  {
    id: 'vip',
    tierKey: 'vip',
    name: 'Fresh Face VIP',
    price: 139,
    tagline: "The \u201cThis Is My Self-Care Ritual\u201d Tier",
    accent: 'sage',
    featured: true,
    ribbon: 'Most Popular',
    ctaLabel: 'Join VIP Tier',
    perks: [
      { label: '1 Custom Facial per month', note: 'normally $140' },
      { label: '15% off all add-on services' },
      { label: '15% off future product purchases' },
      { label: 'Earn 2 points per $1 spent' },
      { label: '1 free add-on per quarter — dermaplaning, microdermabrasion, or brow service (your choice)' },
      { label: 'Free birthday lash lift & tint OR brow lamination & tint' },
      { label: 'Priority booking — VIPs book before the public calendar opens' },
      { label: '48-hour early access to seasonal specials' },
    ],
  },
  {
    id: 'luxe',
    tierKey: 'luxe',
    name: 'Fresh Face Luxe',
    price: 199,
    tagline: "The \u201cI Want It All\u201d Tier",
    accent: 'gold',
    featured: false,
    ribbon: null,
    ctaLabel: 'Join Luxe Tier',
    perks: [
      { label: '1 Custom Facial per month' },
      { label: '1 additional service per month', note: 'any treatment up to $150 value' },
      { label: '20% off all add-on services' },
      { label: '20% off future product purchases' },
      { label: 'Earn 3 points per $1 spent' },
      { label: 'Free birthday microneedling session', note: 'normally $250' },
      { label: 'Priority booking' },
      { label: 'First access to new treatments and seasonal specials' },
      { label: '1 complimentary house call per quarter' },
    ],
  },
];

const rewards = [
  { points: 250, reward: 'Free add-on service' },
  { points: 500, reward: '$25 off any treatment' },
  { points: 1000, reward: 'Free Classic Facial' },
  { points: 1500, reward: 'Free Custom Facial' },
  { points: 2500, reward: 'Free Microneedling session' },
];

const faqs = [
  {
    q: 'Can I cancel anytime?',
    a: "Yes. There's no long-term contract. Cancel anytime and your benefits remain active through the end of your billing cycle.",
  },
  {
    q: 'What happens if I miss my monthly facial?',
    a: "Unused monthly facials don't roll over, but we make it easy to book — and your text reminders will keep you on track. Life happens though, so reach out and we'll work with you.",
  },
  {
    q: 'Can I upgrade or downgrade my tier?',
    a: 'Absolutely. Changes take effect at your next billing cycle.',
  },
  {
    q: 'Do my points expire?',
    a: 'Never, as long as your membership is active. If you cancel, you have 90 days to use remaining points.',
  },
  {
    q: 'Can I share my membership with someone else?',
    a: 'Memberships are individual, but gift cards make a great way to share the Fresh Face love.',
  },
  {
    q: 'Can I use my member discount on gift cards?',
    a: 'Member discounts apply to services and products only, not gift card purchases.',
  },
];
---

<BaseLayout
  title="Membership Plans"
  description="Join a Fresh Face membership for monthly facials, exclusive discounts, loyalty points, and VIP perks. Three tiers starting at $89/mo. North Myrtle Beach skincare studio."
>
  <Header slot="header" currentPath="/membership" />

  <!-- STATUS BANNERS (shown via JS based on ?success / ?cancelled query) -->
  <div
    id="membership-banner-success"
    class="membership-banner membership-banner--success"
    role="status"
    hidden
  >
    <div class="container">
      <p>
        <strong>Welcome to the Fresh Face family! 🎉</strong>
        You'll receive a confirmation email shortly. Book your first member facial
        anytime at <a href="/book">/book</a>.
      </p>
      <button
        type="button"
        class="membership-banner__close"
        aria-label="Dismiss"
        data-banner-close
      >×</button>
    </div>
  </div>

  <div
    id="membership-banner-cancelled"
    class="membership-banner membership-banner--cancelled"
    role="status"
    hidden
  >
    <div class="container">
      <p>
        <strong>No worries — take your time.</strong>
        We'll be here when you're ready.
      </p>
      <button
        type="button"
        class="membership-banner__close"
        aria-label="Dismiss"
        data-banner-close
      >×</button>
    </div>
  </div>

  <!-- FULL-BLEED HERO -->
  <section class="page-hero-img" aria-label="Fresh Face Membership hero">
    <img
      src="/images/facial-relaxed.jpg"
      alt="Relaxing facial treatment at Fresh Face Studio"
      class="page-hero-img__bg"
      loading="eager"
    />
    <div class="page-hero-img__content">
      <p class="membership-eyebrow">Membership</p>
      <h1>The Fresh Face Membership</h1>
      <p>
        Your skin doesn't take months off. Neither should your skincare. Choose a membership
        tier and make Fresh Face part of your routine — with exclusive perks, points, and savings.
      </p>
    </div>
  </section>

  <!-- TIERS -->
  <section class="section tiers-section" id="tiers" aria-labelledby="tiers-heading">
    <div class="container container--wide">
      <div class="section-header">
        <p class="section-header__eyebrow">Choose Your Tier</p>
        <h2 id="tiers-heading">Three Ways to Join</h2>
        <p class="text-secondary" style="margin-top: var(--space-md);">
          Every tier includes a monthly facial, member discounts, and loyalty points.
          Pick the one that fits the rhythm of your routine.
        </p>
      </div>
      <div class="tiers-grid">
        {tiers.map((tier) => (
          <article
            class:list={[
              'tier-card',
              `tier-card--${tier.accent}`,
              { 'tier-card--featured': tier.featured },
            ]}
            aria-labelledby={`${tier.id}-heading`}
          >
            {tier.ribbon && <div class="tier-card__ribbon">{tier.ribbon}</div>}
            <div class="tier-card__inner">
              <header class="tier-card__header">
                <p class="tier-card__badge">{tier.name.replace('Fresh Face ', '')}</p>
                <h3 id={`${tier.id}-heading`} class="tier-card__name">{tier.name}</h3>
                <p class="tier-card__tagline">{tier.tagline}</p>
                <div class="tier-card__price">
                  <span class="tier-card__amount">${tier.price}</span>
                  <span class="tier-card__per">/ month</span>
                </div>
              </header>
              <ul class="tier-card__perks">
                {tier.perks.map((perk) => (
                  <li class="tier-card__perk">
                    <span class="tier-card__check" aria-hidden="true">✦</span>
                    <span>
                      {perk.label}
                      {perk.note && <em class="tier-card__note"> ({perk.note})</em>}
                    </span>
                  </li>
                ))}
              </ul>
              <div class="tier-card__footer">
                <button
                  type="button"
                  data-tier={tier.tierKey}
                  class:list={[
                    'btn',
                    'tier-card__btn',
                    'tier-card__cta',
                    tier.featured ? 'btn--primary' : 'btn--secondary',
                  ]}
                >
                  <span class="tier-card__cta-label">{tier.ctaLabel}</span>
                </button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- POINTS REWARDS -->
  <section class="section section--sage rewards-section" aria-labelledby="rewards-heading">
    <div class="container container--narrow">
      <div class="section-header">
        <p class="section-header__eyebrow" style="color: var(--color-sage-dark);">Loyalty Points</p>
        <h2 id="rewards-heading">Your Loyalty, Rewarded</h2>
        <p class="text-secondary" style="margin-top: var(--space-md);">
          Every dollar you spend at Fresh Face earns points. Here's what you can cash them in for.
        </p>
      </div>

      <div class="rewards-table" role="list">
        {rewards.map((row) => (
          <div class="rewards-row" role="listitem">
            <div class="rewards-row__points">
              <span class="rewards-row__number">{row.points.toLocaleString()}</span>
              <span class="rewards-row__label">points</span>
            </div>
            <div class="rewards-row__arrow" aria-hidden="true">→</div>
            <div class="rewards-row__reward">{row.reward}</div>
          </div>
        ))}
      </div>

      <p class="rewards-note">
        Points never expire for active members. If membership is cancelled, points expire after 90 days.
      </p>

      <div class="earn-rates">
        <h3 class="earn-rates__heading">How You Earn</h3>
        <div class="earn-rates__grid">
          <div class="earn-rate earn-rate--bronze">
            <span class="earn-rate__tier">Member</span>
            <span class="earn-rate__value">1 point <em>per $1</em></span>
          </div>
          <div class="earn-rate earn-rate--sage">
            <span class="earn-rate__tier">VIP</span>
            <span class="earn-rate__value">2 points <em>per $1</em></span>
          </div>
          <div class="earn-rate earn-rate--gold">
            <span class="earn-rate__tier">Luxe</span>
            <span class="earn-rate__value">3 points <em>per $1</em></span>
          </div>
        </div>
      </div>

      <div class="earn-example">
        <p>
          <strong>Quick example:</strong> A VIP member spending $139/mo earns 278 points
          per month — that's a free add-on every month and a free Custom Facial twice a year,
          just from your membership alone.
        </p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section how-it-works" aria-labelledby="how-heading">
    <div class="container">
      <div class="section-header">
        <p class="section-header__eyebrow">How It Works</p>
        <h2 id="how-heading">Three Simple Steps</h2>
      </div>
      <div class="steps-grid">
        <div class="step">
          <div class="step__number">01</div>
          <h3 class="step__title">Choose Your Tier</h3>
          <p class="step__body">
            Pick the membership level that matches your skincare goals.
          </p>
        </div>
        <div class="step">
          <div class="step__number">02</div>
          <h3 class="step__title">Book Monthly</h3>
          <p class="step__body">
            Your facial is included every month. Add-ons and extra services at your member discount.
          </p>
        </div>
        <div class="step">
          <div class="step__number">03</div>
          <h3 class="step__title">Earn &amp; Save</h3>
          <p class="step__body">
            Watch your points grow. Redeem for free treatments anytime.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt faq-section" aria-labelledby="faq-heading">
    <div class="container container--narrow">
      <div class="section-header">
        <p class="section-header__eyebrow">Questions, Answered</p>
        <h2 id="faq-heading">Membership FAQ</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-item__q">
              <span>{faq.q}</span>
              <span class="faq-item__icon" aria-hidden="true"></span>
            </summary>
            <div class="faq-item__a">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta" aria-labelledby="final-cta-heading">
    <img
      src="/images/maria-headshot.jpg"
      alt="Maria at Fresh Face Studio"
      class="final-cta__bg"
      loading="lazy"
    />
    <div class="final-cta__overlay"></div>
    <div class="container final-cta__content">
      <p class="membership-eyebrow" style="color: var(--color-terracotta);">Ready to Glow?</p>
      <h2 id="final-cta-heading">Your Skin Will Thank You</h2>
      <p>
        Join the Fresh Face family. Pick your tier, book your first visit, and let's build
        a skincare routine that actually works.
      </p>
      <a href="#tiers" class="btn btn--primary btn--lg">Choose Your Membership</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ===== HERO EYEBROW ===== */
  .membership-eyebrow {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-terracotta);
    margin-bottom: var(--space-sm);
  }

  /* ===== TIERS ===== */
  .tiers-section {
    background: var(--bg-primary);
  }

  .tiers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: stretch;
  }
  @media (min-width: 960px) {
    .tiers-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
      align-items: start;
    }
  }

  .tier-card {
    position: relative;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    display: flex;
    flex-direction: column;
  }
  .tier-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(44, 40, 37, 0.1);
  }

  .tier-card--bronze { border-top: 4px solid var(--color-terracotta); }
  .tier-card--sage { border-top: 4px solid var(--color-sage); }
  .tier-card--gold { border-top: 4px solid #C8A671; }

  .tier-card--featured {
    border: 1px solid var(--color-sage);
    box-shadow: 0 10px 40px rgba(139, 158, 135, 0.22);
    transform: translateY(-8px);
  }
  .tier-card--featured:hover {
    transform: translateY(-12px);
    box-shadow: 0 16px 48px rgba(139, 158, 135, 0.28);
  }
  .tier-card--featured.tier-card--sage { border-top-width: 6px; }

  @media (max-width: 959px) {
    /* Mobile: VIP stacks on top */
    .tier-card--featured {
      order: -1;
      transform: none;
    }
  }

  .tier-card__ribbon {
    position: absolute;
    top: var(--space-lg);
    right: -36px;
    background: var(--color-sage-dark);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.4rem 3rem;
    transform: rotate(35deg);
    box-shadow: 0 4px 12px rgba(107, 127, 103, 0.3);
    z-index: 2;
  }

  .tier-card__inner {
    padding: var(--space-2xl) var(--space-xl);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tier-card__header {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-lg);
  }

  .tier-card__badge {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: var(--space-md);
  }
  .tier-card--bronze .tier-card__badge { color: var(--color-terracotta); }
  .tier-card--sage .tier-card__badge { color: var(--color-sage-dark); }
  .tier-card--gold .tier-card__badge { color: #A47F49; }

  .tier-card__name {
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-xs);
    line-height: 1.2;
  }

  .tier-card__tagline {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-style: italic;
    line-height: 1.5;
    margin-bottom: var(--space-lg);
  }

  .tier-card__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-xs);
  }
  .tier-card__amount {
    font-family: var(--font-serif);
    font-size: 2.75rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
  }
  .tier-card__per {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
  }

  .tier-card__perks {
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
  }
  .tier-card__perk {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding: var(--space-sm) 0;
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--text-primary);
  }
  .tier-card__perk + .tier-card__perk {
    border-top: 1px solid rgba(221, 214, 205, 0.5);
  }
  .tier-card__check {
    flex-shrink: 0;
    font-size: var(--text-base);
    line-height: 1.5;
    margin-top: 1px;
  }
  .tier-card--bronze .tier-card__check { color: var(--color-terracotta); }
  .tier-card--sage .tier-card__check { color: var(--color-sage-dark); }
  .tier-card--gold .tier-card__check { color: #C8A671; }

  .tier-card__note {
    color: var(--text-secondary);
    font-style: italic;
    font-size: var(--text-xs);
  }

  .tier-card__footer {
    padding-top: var(--space-xl);
    margin-top: var(--space-lg);
    border-top: 1px solid var(--border);
  }
  .tier-card__btn {
    width: 100%;
    justify-content: center;
  }

  /* ===== REWARDS ===== */
  .rewards-section {
    background: var(--color-sage-light);
  }

  .rewards-table {
    background: var(--bg-primary);
    border-radius: var(--border-radius-lg);
    padding: var(--space-lg) var(--space-xl);
    box-shadow: 0 4px 24px rgba(44, 40, 37, 0.06);
    margin-top: var(--space-xl);
  }
  .rewards-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-columns: 140px auto 1fr;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--border);
  }
  .rewards-row:last-child { border-bottom: none; }

  @media (max-width: 600px) {
    .rewards-row {
      grid-template-columns: 100px auto 1fr;
      gap: var(--space-sm);
      padding: var(--space-md) 0;
    }
  }

  .rewards-row__points {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.1;
  }
  .rewards-row__number {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-sage-dark);
  }
  .rewards-row__label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }
  .rewards-row__arrow {
    color: var(--color-sage);
    font-size: var(--text-xl);
    font-weight: 300;
  }
  .rewards-row__reward {
    font-size: var(--text-base);
    color: var(--text-primary);
    font-weight: 500;
  }
  @media (max-width: 600px) {
    .rewards-row__number { font-size: var(--text-xl); }
    .rewards-row__reward { font-size: var(--text-sm); }
  }

  .rewards-note {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-style: italic;
    margin-top: var(--space-lg);
  }

  .earn-rates {
    margin-top: var(--space-3xl);
    text-align: center;
  }
  .earn-rates__heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
  }
  .earn-rates__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    max-width: 560px;
    margin: 0 auto;
  }
  .earn-rate {
    background: var(--bg-primary);
    border-radius: var(--border-radius);
    padding: var(--space-lg) var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    border-top: 3px solid transparent;
  }
  .earn-rate--bronze { border-top-color: var(--color-terracotta); }
  .earn-rate--sage { border-top-color: var(--color-sage); }
  .earn-rate--gold { border-top-color: #C8A671; }

  .earn-rate__tier {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }
  .earn-rate__value {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
  }
  .earn-rate__value em {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    font-style: normal;
    display: block;
    font-family: var(--font-sans);
    font-weight: 500;
    margin-top: 2px;
  }

  .earn-example {
    margin-top: var(--space-2xl);
    padding: var(--space-xl);
    background: var(--bg-primary);
    border-left: 3px solid var(--color-sage);
    border-radius: var(--border-radius);
  }
  .earn-example p {
    font-size: var(--text-base);
    color: var(--text-primary);
    line-height: 1.7;
  }

  /* ===== HOW IT WORKS ===== */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }
  @media (min-width: 768px) {
    .steps-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .step {
    text-align: center;
    padding: 0 var(--space-md);
  }
  .step__number {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 500;
    color: var(--color-terracotta);
    margin-bottom: var(--space-md);
    line-height: 1;
    opacity: 0.85;
  }
  .step__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }
  .step__body {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ===== FAQ ===== */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .faq-item {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--border-radius);
    overflow: hidden;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }
  .faq-item[open] {
    border-color: var(--color-sage);
    box-shadow: 0 4px 20px rgba(44, 40, 37, 0.06);
  }
  .faq-item__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-xl);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .faq-item__q::-webkit-details-marker { display: none; }

  .faq-item__icon {
    flex-shrink: 0;
    position: relative;
    width: 16px;
    height: 16px;
  }
  .faq-item__icon::before,
  .faq-item__icon::after {
    content: '';
    position: absolute;
    background: var(--color-terracotta);
    border-radius: 1px;
    transition: transform var(--transition-base);
  }
  .faq-item__icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    transform: translateY(-50%);
  }
  .faq-item__icon::after {
    left: 50%;
    top: 0;
    width: 2px;
    height: 100%;
    transform: translateX(-50%);
  }
  .faq-item[open] .faq-item__icon::after {
    transform: translateX(-50%) rotate(90deg);
  }

  .faq-item__a {
    padding: 0 var(--space-xl) var(--space-lg);
  }
  .faq-item__a p {
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: var(--text-base);
  }

  @media (max-width: 600px) {
    .faq-item__q {
      padding: var(--space-md) var(--space-lg);
      font-size: var(--text-base);
    }
    .faq-item__a {
      padding: 0 var(--space-lg) var(--space-md);
    }
  }

  /* ===== FINAL CTA ===== */
  .final-cta {
    position: relative;
    padding: var(--space-5xl) 0;
    overflow: hidden;
    background: var(--color-charcoal);
  }
  .final-cta__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    z-index: 0;
  }
  .final-cta__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(45, 41, 38, 0.85) 0%, rgba(45, 41, 38, 0.55) 100%);
    z-index: 1;
  }
  .final-cta__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 620px;
  }
  .final-cta__content h2 {
    color: white;
    margin-bottom: var(--space-md);
    font-size: var(--text-4xl);
    text-shadow: 0 2px 16px rgba(0,0,0,0.3);
  }
  .final-cta__content p {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--text-lg);
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .final-cta { padding: var(--space-4xl) 0; }
    .final-cta__content h2 { font-size: var(--text-3xl); }
  }

  /* ===== STATUS BANNERS ===== */
  .membership-banner {
    padding: var(--space-md) 0;
    font-size: var(--text-base);
    line-height: 1.6;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }
  .membership-banner .container {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
  }
  .membership-banner p {
    margin: 0;
    flex: 1;
  }
  .membership-banner a {
    color: inherit;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .membership-banner--success {
    background: var(--color-sage-light);
    color: var(--color-sage-dark);
  }
  .membership-banner--cancelled {
    background: var(--color-terracotta-light);
    color: #7B5642;
  }
  .membership-banner__close {
    background: none;
    border: none;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    color: inherit;
    opacity: 0.7;
    padding: 0 var(--space-sm);
    transition: opacity var(--transition-fast);
  }
  .membership-banner__close:hover { opacity: 1; }

  /* ===== CTA LOADING STATE ===== */
  .tier-card__cta {
    position: relative;
  }
  .tier-card__cta[data-loading="true"] {
    pointer-events: none;
    opacity: 0.85;
  }
  .tier-card__cta[data-loading="true"] .tier-card__cta-label {
    visibility: hidden;
  }
  .tier-card__cta[data-loading="true"]::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 18px;
    height: 18px;
    margin: -9px 0 0 -9px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: tier-cta-spin 0.7s linear infinite;
  }
  @keyframes tier-cta-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  // Show success/cancelled banner based on query string
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true') {
    document.getElementById('membership-banner-success')?.removeAttribute('hidden');
  }
  if (params.get('cancelled') === 'true') {
    document.getElementById('membership-banner-cancelled')?.removeAttribute('hidden');
  }

  // Banner dismiss
  document.querySelectorAll('[data-banner-close]').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('.membership-banner')?.setAttribute('hidden', '');
    });
  });

  // Stripe Checkout handlers
  const tierButtons = document.querySelectorAll<HTMLButtonElement>('[data-tier]');
  tierButtons.forEach((btn) => {
    btn.addEventListener('click', async () => {
      const tier = btn.getAttribute('data-tier');
      if (!tier) return;

      btn.setAttribute('data-loading', 'true');
      btn.disabled = true;

      try {
        const res = await fetch('/api/create-membership', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier }),
        });

        if (!res.ok) {
          throw new Error('Checkout request failed');
        }

        const data = await res.json();
        if (data?.url) {
          window.location.href = data.url;
        } else {
          throw new Error('No checkout URL returned');
        }
      } catch (err) {
        console.error('Membership checkout error:', err);
        btn.removeAttribute('data-loading');
        btn.disabled = false;
        alert('Sorry, we could not start checkout. Please try again or call us.');
      }
    });
  });
</script>
