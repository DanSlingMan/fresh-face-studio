---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { business, services, serviceCategories } from '../data/site';
---

<BaseLayout
  title="Skincare Services"
  description="Facials, chemical peels, microneedling, dermaplaning, lash lifts, brow lamination & waxing in North Myrtle Beach, SC. View all services and pricing at Fresh Face Studio."
>
  <Header slot="header" currentPath="/services" />

  <!-- FULL-BLEED HERO -->
  <section class="page-hero-img" aria-label="Services hero">
    <img
      src="/images/facial-application.jpg"
      alt="Skincare product application at Fresh Face Studio"
      class="page-hero-img__bg"
      loading="eager"
    />
    <div class="page-hero-img__content">
      <p class="services-eyebrow">What We Offer</p>
      <h1>Our Services</h1>
      <p>
        Every face that walks in here gets treated like the only one that matters — because
        right now, it is. No templates. No scripts. Just Maria, your skin, and a plan
        that's actually yours.
      </p>
    </div>
  </section>

  <!-- SERVICE CATEGORIES -->
  {serviceCategories.map((category, i) => {
    const categoryServices = services.filter(s => s.category === category.slug);
    if (categoryServices.length === 0) return null;
    const isAlt = i % 2 !== 0;
    return (
      <section class={`section category-section${isAlt ? ' section--alt' : ''}`} id={category.slug}>
        <div class="container">
          <div class="category-header">
            <h2>{category.name}</h2>
            <p class="text-secondary">{category.description}</p>
          </div>
          <div class="services-grid">
            {categoryServices.map(service => (
              <ServiceCard {...service} />
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <!-- CONSULTATION CTA -->
  <section class="section section--charcoal">
    <div class="container container--narrow" style="text-align:center;">
      <p class="section-header__eyebrow" style="color:var(--color-terracotta);">Not Sure Where to Start?</p>
      <h2 style="color:white; margin-bottom:var(--space-md);">Book a Free Consultation</h2>
      <p style="color:rgba(255,255,255,0.8); margin-bottom:var(--space-xl); max-width:520px; margin-left:auto; margin-right:auto;">
        We'll look at your skin, talk about your concerns,
        and recommend the treatment that will actually make a difference — not the most expensive one.
      </p>
      <a href="/book" class="btn btn--primary btn--lg">
        Book a Free Consultation
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .services-eyebrow {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-terracotta);
    margin-bottom: var(--space-sm);
  }

  .category-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }
  .category-header h2 {
    margin-bottom: var(--space-sm);
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 600px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
