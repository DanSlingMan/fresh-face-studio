---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!--
  PROVISIONAL DESIGN — uses current Astro design system.
  Will be reskinned as part of the full GlossGenius visual clone redesign.
  Content and structure are accurate; visual treatment is temporary.
-->
<BaseLayout
  title="Shop | Memberships, Packages & Gift Cards"
  description="Memberships, treatment packages, and gift cards from Fresh Face Studio in North Myrtle Beach. Save when you commit to your skin — or give the gift of glow."
>
  <Header slot="header" currentPath="/shop" />

  <!-- HERO -->
  <section class="shop-hero">
    <div class="container container--narrow shop-hero__inner">
      <p class="shop-eyebrow">Beyond the Single Visit</p>
      <h1>Shop the Studio</h1>
      <p class="shop-hero__lede">
        Three ways to make Fresh Face part of your routine — or someone else's day.
      </p>
    </div>
  </section>

  <!-- THREE-CARD GRID -->
  <section class="section">
    <div class="container">
      <div class="shop-grid">

        <a href="/shop/memberships" class="shop-card" aria-label="Membership details">
          <p class="shop-card__eyebrow">Monthly</p>
          <h2 class="shop-card__title">Membership</h2>
          <p class="shop-card__body">
            One Classic Facial and a Full-face Dermaplaning every month, for $125. Skin
            care that keeps showing up — even when life doesn't.
          </p>
          <span class="shop-card__link">Explore Membership <span aria-hidden="true">&rarr;</span></span>
        </a>

        <a href="/shop/packages" class="shop-card" aria-label="Treatment packages">
          <p class="shop-card__eyebrow">Pre-Paid Series</p>
          <h2 class="shop-card__title">Packages</h2>
          <p class="shop-card__body">
            Microneedling. Custom Facial + Dermaplane combos. The Get-Ready-For-Summer
            collagen series. Buy them in bulk and save up to $400.
          </p>
          <span class="shop-card__link">Explore Packages <span aria-hidden="true">&rarr;</span></span>
        </a>

        <a href="/shop/gift-cards" class="shop-card" aria-label="Gift cards">
          <p class="shop-card__eyebrow">For Someone Else</p>
          <h2 class="shop-card__title">Gift Cards</h2>
          <p class="shop-card__body">
            $50, $75, $100, $200, or whatever you want. Pick a design, write a note,
            schedule the delivery. They get a permission slip to slow down.
          </p>
          <span class="shop-card__link">Send a Gift Card <span aria-hidden="true">&rarr;</span></span>
        </a>

      </div>
    </div>
  </section>

  <!-- WHY-IT-MATTERS STRIP -->
  <section class="section section--alt">
    <div class="container container--narrow" style="text-align:center;">
      <p class="shop-eyebrow">Why Bundle</p>
      <h2 style="margin-bottom:var(--space-md);">Skin Rewards Consistency</h2>
      <p class="text-secondary text-lg">
        One facial feels great. Six facials change your skin. Memberships and packages
        exist because the results compound — and so do the savings.
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .shop-eyebrow {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-terracotta);
    margin-bottom: var(--space-sm);
  }

  .shop-hero {
    background: var(--bg-secondary);
    padding: var(--space-4xl) 0 var(--space-3xl);
    text-align: center;
  }
  .shop-hero__inner h1 {
    margin-bottom: var(--space-md);
  }
  .shop-hero__lede {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 36rem;
    margin: 0 auto;
  }

  .shop-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 800px) {
    .shop-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .shop-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .shop-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(44, 40, 37, 0.1);
    border-color: var(--accent);
  }
  .shop-card__eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }
  .shop-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-md);
  }
  .shop-card__body {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-lg);
    flex: 1;
  }
  .shop-card__link {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-terracotta);
  }
</style>