---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { GLOSSGENIUS_URLS } from '../../data/site';

const packages = [
  {
    name: 'Microneedling Package',
    price: '$750',
    save: 'Save $250',
    blurb: 'Buy three Microneedling sessions, get the fourth free. Microneedling builds collagen over time, so the results compound — and so do the savings when you commit to the full series.',
    bestFor: 'Acne scarring, fine lines, melasma, deep texture concerns.',
  },
  {
    name: 'Custom Facial & Dermaplane Combo',
    price: '$1,880',
    save: 'Save $400',
    blurb: 'Buy ten visits, get twelve. One Custom Facial plus Full-face Dermaplaning every month for a year. Roughly two hours of care monthly — the same rhythm as the membership, just paid up front and locked in for twelve months.',
    bestFor: 'Anyone planning to make Fresh Face their year-round routine.',
  },
  {
    name: 'Get-Ready-For-Summer Series',
    price: '$665',
    save: 'Save $190',
    blurb: 'Four collagen-producing treatments spaced over sixteen weeks. Designed to be timed for spring so your skin is at its best by beach season — but the protocol works whenever you start.',
    bestFor: 'Pre-vacation prep, wedding skin, "I want to look like myself in photos" energy.',
  },
];
---

<!--
  PROVISIONAL DESIGN — uses current Astro design system.
  Will be reskinned as part of the full GlossGenius visual clone redesign.
  Content and structure are accurate; visual treatment is temporary.
-->
<BaseLayout
  title="Treatment Packages & Series"
  description="Pre-paid packages for Microneedling, Custom Facial + Dermaplane, and our Get-Ready-For-Summer series. Save up to $400 at Fresh Face Studio."
>
  <Header slot="header" currentPath="/shop" />

  <!-- HERO -->
  <section class="shop-hero">
    <div class="container container--narrow shop-hero__inner">
      <p class="shop-eyebrow">Commit Once, Save Often</p>
      <h1>Treatment Packages</h1>
      <p class="shop-hero__lede">
        Some treatments work best as a series. Buy them in bulk, save real money, and
        let the results compound the way they're supposed to.
      </p>
    </div>
  </section>

  <!-- PACKAGE CARDS -->
  <section class="section">
    <div class="container">
      <div class="package-grid">
        {packages.map(pkg => (
          <article class="package-card">
            <div class="package-card__top">
              <h2 class="package-card__name">{pkg.name}</h2>
              <div class="package-card__price-row">
                <span class="package-card__price">{pkg.price}</span>
                <span class="package-card__save">{pkg.save}</span>
              </div>
            </div>
            <div class="package-card__body">
              <p class="package-card__blurb">{pkg.blurb}</p>
              <p class="package-card__best">
                <strong>Best for:</strong> {pkg.bestFor}
              </p>
            </div>
            <div class="package-card__cta">
              <a
                href={GLOSSGENIUS_URLS.packages}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--primary"
              >
                Purchase Package
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY SERIES -->
  <section class="section section--alt">
    <div class="container container--narrow">
      <p class="shop-eyebrow">Why Pay Up Front</p>
      <h2 style="margin-bottom:var(--space-lg);">Because Skincare Compounds</h2>
      <p class="text-secondary text-lg" style="margin-bottom:var(--space-md);">
        Microneedling, peels, and collagen-stimulating treatments build on each other —
        one session lays the foundation, the next adds to it, and by the third or fourth
        you're seeing results that a single visit can't deliver. That's why these are
        sold as series at every legitimate skincare studio.
      </p>
      <p class="text-secondary text-lg">
        Pre-paying isn't just about the discount. It's about not bailing on yourself
        when life gets busy.
      </p>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="section section--charcoal">
    <div class="container container--narrow" style="text-align:center;">
      <p class="section-header__eyebrow" style="color:var(--color-terracotta);">Not Sure Which One?</p>
      <h2 style="color:white; margin-bottom:var(--space-md);">Ask First. Buy Second.</h2>
      <p style="color:rgba(255,255,255,0.8); margin-bottom:var(--space-xl); max-width:520px; margin-left:auto; margin-right:auto;">
        Every package is sold through GlossGenius, but if you want to talk through which
        one fits your skin and your goals — book a free consultation first. No pressure.
      </p>
      <div style="display:flex; gap:var(--space-md); justify-content:center; flex-wrap:wrap;">
        <a
          href={GLOSSGENIUS_URLS.packages}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--primary btn--lg"
        >
          Browse Packages
        </a>
        <a href="/book" class="btn btn--outline-white btn--lg">
          Book a Consultation
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .shop-eyebrow {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-terracotta);
    margin-bottom: var(--space-sm);
  }

  .shop-hero {
    background: var(--bg-secondary);
    padding: var(--space-4xl) 0 var(--space-3xl);
    text-align: center;
  }
  .shop-hero__inner h1 {
    margin-bottom: var(--space-md);
  }
  .shop-hero__lede {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 38rem;
    margin: 0 auto;
  }

  .package-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }
  @media (min-width: 900px) {
    .package-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .package-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--border-radius-lg);
    padding: var(--space-xl);
    transition: box-shadow var(--transition-base), border-color var(--transition-base), transform var(--transition-base);
  }
  .package-card:hover {
    box-shadow: 0 8px 32px rgba(44, 40, 37, 0.1);
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .package-card__top {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }
  .package-card__name {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }
  .package-card__price-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }
  .package-card__price {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--color-terracotta);
  }
  .package-card__save {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-sage-dark);
  }
  .package-card__body {
    flex: 1;
    margin-bottom: var(--space-lg);
  }
  .package-card__blurb {
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: var(--space-md);
  }
  .package-card__best {
    font-size: var(--text-sm);
    color: var(--text-primary);
  }
  .package-card__cta a { width: 100%; justify-content: center; }
</style>
